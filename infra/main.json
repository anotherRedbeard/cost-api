{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "17569229708166880251"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string"
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "defaultTimeframe": {
      "type": "string",
      "defaultValue": "MonthToDate",
      "allowedValues": [
        "MonthToDate",
        "TheLastMonth",
        "TheLastWeek",
        "TheLastYear",
        "WeekToDate",
        "BillingMonthToDate",
        "TheLastBillingMonth"
      ]
    },
    "defaultGranularity": {
      "type": "string",
      "defaultValue": "Daily",
      "allowedValues": [
        "Daily",
        "None"
      ]
    },
    "maximumInstanceCount": {
      "type": "int",
      "defaultValue": 100,
      "minValue": 40,
      "maxValue": 1000
    },
    "instanceMemoryMB": {
      "type": "int",
      "defaultValue": 2048,
      "allowedValues": [
        2048,
        4096
      ]
    }
  },
  "variables": {
    "suffix": "[uniqueString(subscription().subscriptionId, resourceGroup().id, parameters('environmentName'))]",
    "functionAppName": "[take(format('func-{0}-cost-{1}', parameters('environmentName'), variables('suffix')), 60)]",
    "storageAccountName": "[toLower(take(format('st{0}', variables('suffix')), 24))]",
    "hostingPlanName": "[take(format('plan-{0}-cost-{1}', parameters('environmentName'), variables('suffix')), 40)]",
    "appInsightsName": "[take(format('appi-{0}-cost-{1}', parameters('environmentName'), variables('suffix')), 60)]",
    "workspaceName": "[take(format('log-{0}-cost-{1}', parameters('environmentName'), variables('suffix')), 63)]",
    "deploymentIdentityName": "[take(format('uai-{0}-deploy-{1}', parameters('environmentName'), variables('suffix')), 64)]",
    "deploymentStorageContainerName": "[take(format('app-package-{0}-{1}', toLower(parameters('environmentName')), variables('suffix')), 63)]",
    "storageBlobDataOwnerRoleId": "b7e6dc6d-f1e8-4753-8033-0f276bb0955b",
    "storageBlobDataContributorRoleId": "ba92f5b4-2d11-453d-a403-e96b0029c9fe",
    "storageQueueDataContributorRoleId": "974c5e8b-45b9-4653-ba55-5f855dd0fb88",
    "storageTableDataContributorRoleId": "0a9a7e1f-b9d0-4cc4-a60d-0319b160aaa3",
    "tags": {
      "azd-env-name": "[parameters('environmentName')]",
      "app": "cost-api-demo"
    }
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
